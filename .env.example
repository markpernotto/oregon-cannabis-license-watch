# Postgres — local via docker-compose, or Neon connection string in prod.
DATABASE_URL=postgresql://oc_data:oc_data@localhost:5432/oc_data

# Object storage for raw snapshot archival.
# Cloudflare R2 (Phase 1 default) uses S3-compatible API.
# Set these to enable archival; extract runs without them in dev.
OBJECT_STORE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
OBJECT_STORE_ACCESS_KEY=
OBJECT_STORE_SECRET_KEY=
OBJECT_STORE_BUCKET=oc-data-snapshots
OBJECT_STORE_REGION=auto

# Extraction identity sent as User-Agent when fetching public data.
EXTRACTOR_USER_AGENT=OregonCannabisDataProject/0.1 (+mark@pernotto.com)
